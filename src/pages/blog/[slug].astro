---
import { marked } from "marked";
import Layout from "../../layouts/Layout.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { supabasePublic } from "../../lib/supabase";

const { slug } = Astro.params;

const { data: post } = await supabasePublic.from("posts").select("*").eq("slug", slug).eq("published", true).single();

if (!post) {
  return Astro.redirect("/blog");
}

const contentHtml = marked.parse(post.content);
---

<Layout title={post.title} description={post.description}>
  <article class="bg-white">
    <div class="mx-auto max-w-3xl px-5 py-16 md:px-8 md:py-20">
      <p class="text-xs font-semibold uppercase tracking-wide text-ink-soft">
        {new Date(post.published_at).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" })}
        · {post.author}
      </p>
      <h1 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight text-ink md:text-4xl">
        {post.title}
      </h1>

      <div class="prose prose-emerald mt-8 max-w-none text-ink-soft prose-headings:text-ink prose-a:text-brand" set:html={contentHtml} />

      <div class="mt-12 rounded-3xl bg-ink px-6 py-10 text-center">
        <h2 class="text-xl font-extrabold text-white md:text-2xl">Quer conversar sobre seu caso?</h2>
        <p class="mt-2 text-emerald-50/80">Me manda uma mensagem no WhatsApp.</p>
        <div class="mt-6 flex justify-center">
          <WhatsAppButton label="Falar no WhatsApp" class="bg-pink-deep hover:bg-pink-deep" />
        </div>
      </div>
    </div>
  </article>
</Layout>
