---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<Layout title="Blog">
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 md:px-8 md:py-20">
      <span
        class="inline-flex items-center rounded-full bg-pink-soft px-4 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-pink-deep"
      >
        Blog
      </span>
      <h1 class="mt-5 text-4xl font-extrabold leading-[1.1] tracking-tight text-ink md:text-5xl">
        Conteúdo sobre cuidado e fisioterapia
      </h1>

      {
        posts.length === 0 ? (
          <p class="mt-8 text-ink-soft">Em breve, novos textos por aqui.</p>
        ) : (
          <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="flex flex-col rounded-2xl border border-mint-border bg-mint p-6 transition-colors duration-200 hover:border-brand"
              >
                <p class="text-xs font-semibold uppercase tracking-wide text-ink-soft">
                  {post.data.publishedAt.toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" })}
                </p>
                <p class="mt-2 text-lg font-bold text-ink">{post.data.title}</p>
                <p class="mt-2 leading-relaxed text-ink-soft">{post.data.description}</p>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>
