---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
---

<Layout title="Página não encontrada">
  <section class="overflow-hidden bg-white">
    <div class="relative mx-auto max-w-xl px-5 py-24 text-center md:px-8">
      <div class="absolute left-1/2 top-6 h-44 w-44 -translate-x-1/2 rounded-full bg-mint blur-3xl" aria-hidden="true"></div>
      <div class="absolute left-1/2 top-20 h-32 w-32 -translate-x-[80%] rounded-full bg-pink-soft blur-3xl" aria-hidden="true"></div>

      <div class="relative mx-auto flex h-16 w-16 items-center justify-center rounded-2xl border border-mint-border bg-mint">
        <Icon name="mappin" class="h-8 w-8 text-brand" />
      </div>

      <p class="relative mt-6 text-sm font-bold uppercase tracking-[0.18em] text-pink-deep">Erro 404</p>
      <h1 class="relative mt-3 text-3xl font-extrabold tracking-tight text-ink">Página não encontrada</h1>
      <p class="relative mt-4 leading-relaxed text-ink-soft">
        A página que você procura não existe ou foi movida. Que tal voltar pro início ou me
        chamar direto no WhatsApp?
      </p>
      <div class="relative mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <WhatsAppButton label="Falar no WhatsApp" />
        <a href="/" class="inline-flex items-center gap-1.5 text-base font-semibold text-brand">
          Voltar ao início
        </a>
      </div>
    </div>
  </section>
</Layout>
