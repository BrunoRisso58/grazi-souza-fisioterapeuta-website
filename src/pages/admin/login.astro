---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { createSessionCookieValue, isValidSession, SESSION_COOKIE_NAME, SESSION_MAX_AGE, verifyPassword } from "../../lib/auth";

const existing = Astro.cookies.get(SESSION_COOKIE_NAME)?.value;
if (isValidSession(existing, import.meta.env.SESSION_SECRET)) {
  return Astro.redirect("/admin");
}

let error = false;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const password = String(form.get("password") ?? "");

  if (verifyPassword(password, import.meta.env.ADMIN_PASSWORD, import.meta.env.SESSION_SECRET)) {
    Astro.cookies.set(SESSION_COOKIE_NAME, createSessionCookieValue(import.meta.env.SESSION_SECRET), {
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: "lax",
      path: "/",
      maxAge: SESSION_MAX_AGE,
    });
    return Astro.redirect("/admin");
  }

  error = true;
}
---

<AdminLayout title="Entrar" showNav={false}>
  <div class="mx-auto max-w-sm rounded-3xl border border-mint-border bg-white p-8 shadow-xl shadow-emerald-900/5">
    <h1 class="text-2xl font-extrabold tracking-tight text-ink">Entrar no painel</h1>
    <p class="mt-1 text-sm text-ink-soft">Pra escrever e publicar artigos no blog.</p>

    <form method="POST" class="mt-6 space-y-4">
      <div>
        <label for="password" class="text-sm font-semibold text-ink">Senha</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autofocus
          class="mt-1 w-full rounded-xl border border-mint-border px-4 py-2.5 text-ink outline-none focus:border-brand"
        />
      </div>

      {error && <p class="text-sm font-semibold text-pink-deep">Senha incorreta.</p>}

      <button
        type="submit"
        class="w-full rounded-full bg-brand px-5 py-2.5 font-bold text-white hover:bg-brand-dark"
      >
        Entrar
      </button>
    </form>
  </div>
</AdminLayout>
