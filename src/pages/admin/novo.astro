---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isValidSession, SESSION_COOKIE_NAME } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";
import { slugify } from "../../lib/slugify";

const session = Astro.cookies.get(SESSION_COOKIE_NAME)?.value;
if (!isValidSession(session, import.meta.env.SESSION_SECRET)) {
  return Astro.redirect("/admin/login");
}

let error = "";
let values = { title: "", slug: "", description: "", content: "", keywords: "" };

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  values = {
    title: String(form.get("title") ?? ""),
    slug: String(form.get("slug") ?? ""),
    description: String(form.get("description") ?? ""),
    content: String(form.get("content") ?? ""),
    keywords: String(form.get("keywords") ?? ""),
  };
  const publish = form.get("published") === "on";

  const slug = slugify(values.slug || values.title);
  const keywords = values.keywords
    .split(",")
    .map((k) => k.trim())
    .filter(Boolean);

  if (!values.title || !values.description || !values.content || !slug) {
    error = "Preenche título, descrição, conteúdo (e o slug não pode ficar vazio).";
  } else {
    const { error: insertError } = await supabaseAdmin.from("posts").insert({
      slug,
      title: values.title,
      description: values.description,
      content: values.content,
      keywords,
      published: publish,
      published_at: publish ? new Date().toISOString() : null,
    });

    if (insertError) {
      error = insertError.code === "23505" ? "Já existe um artigo com esse slug." : insertError.message;
    } else {
      return Astro.redirect("/admin");
    }
  }
}
---

<AdminLayout title="Novo artigo">
  <a href="/admin" class="text-sm font-semibold text-ink-soft hover:text-brand">&larr; Voltar</a>
  <h1 class="mt-3 text-2xl font-extrabold tracking-tight text-ink">Novo artigo</h1>

  <form method="POST" class="mt-6 space-y-5 rounded-3xl border border-mint-border bg-white p-6">
    <div>
      <label for="title" class="text-sm font-semibold text-ink">Título</label>
      <input
        id="title"
        name="title"
        type="text"
        required
        value={values.title}
        class="mt-1 w-full rounded-xl border border-mint-border px-4 py-2.5 text-ink outline-none focus:border-brand"
      />
    </div>

    <div>
      <label for="slug" class="text-sm font-semibold text-ink">Slug (URL)</label>
      <input
        id="slug"
        name="slug"
        type="text"
        placeholder="deixa em branco pra gerar a partir do título"
        value={values.slug}
        class="mt-1 w-full rounded-xl border border-mint-border px-4 py-2.5 text-ink outline-none focus:border-brand"
      />
    </div>

    <div>
      <label for="description" class="text-sm font-semibold text-ink">Descrição (resumo pra busca e card do blog)</label>
      <textarea
        id="description"
        name="description"
        rows="2"
        required
        class="mt-1 w-full rounded-xl border border-mint-border px-4 py-2.5 text-ink outline-none focus:border-brand"
        >{values.description}</textarea
      >
    </div>

    <div>
      <label for="content" class="text-sm font-semibold text-ink">Conteúdo (markdown: ## pra título, listas com -)</label>
      <textarea
        id="content"
        name="content"
        rows="16"
        required
        class="mt-1 w-full rounded-xl border border-mint-border px-4 py-2.5 font-mono text-sm text-ink outline-none focus:border-brand"
        >{values.content}</textarea
      >
    </div>

    <div>
      <label for="keywords" class="text-sm font-semibold text-ink">Palavras-chave (separadas por vírgula)</label>
      <input
        id="keywords"
        name="keywords"
        type="text"
        value={values.keywords}
        class="mt-1 w-full rounded-xl border border-mint-border px-4 py-2.5 text-ink outline-none focus:border-brand"
      />
    </div>

    <label class="flex items-center gap-2 text-sm font-semibold text-ink">
      <input type="checkbox" name="published" class="h-4 w-4 rounded border-mint-border" />
      Publicar agora
    </label>

    {error && <p class="text-sm font-semibold text-pink-deep">{error}</p>}

    <button type="submit" class="rounded-full bg-brand px-5 py-2.5 font-bold text-white hover:bg-brand-dark">
      Salvar
    </button>
  </form>
</AdminLayout>
