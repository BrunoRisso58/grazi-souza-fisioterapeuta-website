---
import Icon from "./Icon.astro";
import { FAQ_ITEMS } from "../consts";

interface Props {
  title?: string;
  items?: typeof FAQ_ITEMS;
}

const { title = "Perguntas frequentes", items = FAQ_ITEMS } = Astro.props;
---

<div class="mx-auto max-w-3xl">
  <span
    class="inline-flex items-center rounded-full bg-pink-soft px-4 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-pink-deep"
  >
    Tire suas dúvidas
  </span>
  <h2 class="mt-5 text-2xl font-extrabold tracking-tight text-ink md:text-3xl">{title}</h2>

  <div class="mt-8 flex flex-col gap-3">
    {
      items.map((item) => (
        <details class="group rounded-2xl border border-mint-border bg-white p-5 open:border-brand">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
            <span class="text-base font-bold text-ink">{item.q}</span>
            <Icon
              name="plus"
              class="h-5 w-5 flex-none text-pink-deep transition-transform duration-200 group-open:rotate-45"
            />
          </summary>
          <p class="mt-3 leading-relaxed text-ink-soft">{item.a}</p>
        </details>
      ))
    }
  </div>
</div>
