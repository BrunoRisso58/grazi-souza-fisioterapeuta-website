# Copie pra .env (já no .gitignore) e preencha com os valores reais.

# Project Settings > API no dashboard do Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Senha de acesso ao painel /admin (escolha uma senha forte)
ADMIN_PASSWORD=

# String aleatória longa, só pra assinar o cookie de sessão do /admin (gere com: openssl rand -hex 32)
SESSION_SECRET=
